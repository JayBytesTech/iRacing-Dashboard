agent.config.local.json
apps/agent/agent.config.json

# ---- Telemetry & session captures (privacy: may contain real driver names / user IDs) ----
# Sample fixtures that are intentionally committed live under data/sample-sessions/ and are
# whitelisted explicitly below. Everything else telemetry-shaped stays out of git history.
*.ibt
data/recordings/
data/sessions/
# Our own multi-car session recordings (.ndjson) — contain the field's real driver names.
**/data/recordings/
*.ndjson
!data/sample-sessions/**
# Driver's journal DB (personal notes + real driver names) — local only.
**/data/journal.db
**/data/journal.db-*

